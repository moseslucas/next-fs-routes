{
  "name": "next-fs-routes",
  "version": "1.0.2",
  "description": "Next.js-style file-structure routing for Vite apps using React Router data routes.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moseslucas/next-fs-routes.git"
  },
  "homepage": "https://github.com/moseslucas/next-fs-routes#readme",
  "bugs": {
    "url": "https://github.com/moseslucas/next-fs-routes/issues"
  },
  "author": "Moses Lucas (Philippines)",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/browser-router.ts --format esm --dts --clean",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --environment node tests/core.test.ts tests/browser-router.test.ts",
    "test:fixture": "vite build fixtures/vite-app --config fixtures/vite-app/vite.config.ts",
    "pack:check": "npm_config_cache=./.npm-cache npm pack --dry-run",
    "prepublishOnly": "pnpm type-check && pnpm test && pnpm build && pnpm test:fixture"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-router-dom": ">=6.30.0 <8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.1",
    "tsup": "^8.3.5",
    "typescript": "^5.0.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}

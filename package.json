{
  "name": "@moseslucaspogi/next-fs-routes",
  "version": "0.1.0",
  "description": "Next.js-style file-structure routing helpers for Vite apps using React Router data routes.",
  "author": "Moses Lucas (Philippines)",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser-router": {
      "types": "./dist/browser-router.d.ts",
      "import": "./dist/browser-router.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts src/browser-router.ts --format esm --dts --clean",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:fixture": "vite build fixtures/vite-app --config fixtures/vite-app/vite.config.ts",
    "pack:check": "npm_config_cache=./.npm-cache npm pack --dry-run",
    "prepublishOnly": "pnpm type-check && pnpm test && pnpm build && pnpm test:fixture"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-router-dom": ">=6.30.0 <8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.30.1",
    "tsup": "^8.3.5",
    "typescript": "^5.0.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
